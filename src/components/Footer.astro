---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/services/", label: "Services" },
  { href: "/case-studies/", label: "Case studies" },
  { href: "/articles/", label: "Articles" },
  { href: "/#how-we-work", label: "How we work" },
  { href: "/#team", label: "About" },
  { href: "/#contact", label: "Contact" },
];

const serviceLinks = [
  {
    href: "/services/embedded-development-team/",
    label: "Embedded development teams",
  },
  {
    href: "/services/custom-software-development/",
    label: "Custom software development",
  },
  { href: "/services/ai-engineering/", label: "AI engineering" },
  { href: "/services/mvp-to-production/", label: "From MVP to production" },
  {
    href: "/services/internal-team-development/",
    label: "Internal team development",
  },
  { href: "/services/technology-audit/", label: "Technology & security audit" },
  { href: "/services/fractional-cto/", label: "Fractional CTO" },
];
---

<footer class="bg-surface-inverse pt-16 pb-8 text-white/80">
  <div class="mx-auto max-w-[1200px] px-6 lg:px-16">
    <div class="mb-12 grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <picture>
          <source
            srcset="/images/logo/innovise-main-logo.webp"
            type="image/webp"
          />
          <img
            src="/images/logo/innovise-main-logo-opt.png"
            alt="Innovise Technologies"
            width="600"
            height="180"
            class="mb-4 h-10 w-auto"
            style="filter: brightness(0) invert(1);"
          />
        </picture>
        <p class="text-sm leading-relaxed text-white/50">
          Custom software, built for you.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4
          class="font-heading mb-4 text-sm font-semibold tracking-wider text-white uppercase"
        >
          Navigation
        </h4>
        <ul class="space-y-2.5">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="hover:text-brand-400 text-sm text-white/50 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4
          class="font-heading mb-4 text-sm font-semibold tracking-wider text-white uppercase"
        >
          Services
        </h4>
        <ul class="space-y-2.5">
          {
            serviceLinks.map((service) => (
              <li>
                <a
                  href={service.href}
                  class="hover:text-brand-400 text-sm text-white/50 transition-colors"
                >
                  {service.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4
          class="font-heading mb-4 text-sm font-semibold tracking-wider text-white uppercase"
        >
          Connect
        </h4>
        <ul class="space-y-2.5">
          <li>
            <a
              href="https://calendly.com/loren-goinnovise/30min"
              target="_blank"
              rel="noopener noreferrer"
              data-cta="calendly"
              class="hover:text-brand-400 inline-flex items-center gap-2 text-sm text-white/50 transition-colors"
            >
              <svg
                class="h-4 w-4"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                ></path>
              </svg>
              Book a 30-min call
            </a>
          </li>
          <li>
            <a
              href="https://www.linkedin.com/company/innovise-technology"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-brand-400 inline-flex items-center gap-2 text-sm text-white/50 transition-colors"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-8 text-center">
      <p class="text-sm text-white/30">
        &copy; 2026 Innovise, LLC. All rights reserved.
      </p>
    </div>
  </div>
</footer>
