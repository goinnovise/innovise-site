---
const clients = [
  { src: '/images/clients/ai-logo.png', alt: 'AI' },
  { src: '/images/clients/wsos-logo.png', alt: 'WSOS' },
  { src: '/images/clients/savvy-lane-logo.png', alt: 'Savvy Lane' },
  { src: '/images/clients/aw-logo.png', alt: 'AW' },
  { src: '/images/clients/tps-logo.png', alt: 'TPS' },
  { src: '/images/clients/chances-app-logo.webp', alt: 'The Chances App' },
];
---

<section class="py-16 bg-surface-page border-b border-surface-inset">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-16">
    <p class="text-center text-text-tertiary text-sm font-medium tracking-wider uppercase mb-10 animate-on-scroll">
      Trusted by teams who ship
    </p>
    <div class="flex flex-wrap items-center justify-center gap-10 md:gap-16 animate-on-scroll">
      {clients.map((client) => (
        <img
          src={client.src}
          alt={client.alt}
          class="client-logo h-8 md:h-10 max-w-[140px] object-contain"
        />
      ))}
    </div>
  </div>
</section>
