---
const clients = [
  { src: "/images/clients/tallo-logo.svg", alt: "Tallo" },
  { src: "/images/clients/airways-logo-bordered.png", alt: "Airways" },
  { src: "/images/clients/wsos-logo.png", alt: "WSOS" },
  { src: "/images/clients/fluffy-logo.png", alt: "Fluffy" },
  { src: "/images/clients/litesprite-logo.png", alt: "Litesprite" },
  { src: "/images/clients/tps-logo.png", alt: "TPS" },
];
---

<section class="bg-surface-page border-surface-inset border-b py-16">
  <div class="mx-auto max-w-[1200px] px-6 lg:px-16">
    <p
      class="text-text-tertiary animate-on-scroll mb-10 text-center text-sm font-medium tracking-wider uppercase"
    >
      Trusted by teams who ship
    </p>
    <div
      class="animate-on-scroll flex flex-wrap items-center justify-center gap-10 md:gap-16"
    >
      {
        clients.map((client) => (
          <img
            src={client.src}
            alt={client.alt}
            class="client-logo h-8 max-w-[140px] object-contain md:h-10"
          />
        ))
      }
    </div>
  </div>
</section>
