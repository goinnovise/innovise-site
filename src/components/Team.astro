---
const team = [
  {
    name: "Loren Anderson",
    role: "President",
    photo: "/images/team/loren-anderson.jpg",
    bio: "Loren has built software across a broad range of languages, frameworks, and platforms, from scrappy startups to Fortune 50 enterprises. He views software as a tool to solve business problems and tackles every challenge with a pragmatic, efficient approach.",
    linkedin: "https://www.linkedin.com/in/loren-anderson-85953a13/",
  },
  {
    name: "Sam Zamor",
    role: "Engineering",
    photo: "/images/team/sam-zamor.png",
    bio: "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat duis aute irure in nulla.",
    linkedin: "https://www.linkedin.com/in/samzamor",
  },
  {
    name: "Jim Reynolds",
    role: "Operations",
    photo: "/images/team/placeholder-jim-reynolds.svg",
    bio: "Maecenas faucibus mollis interdum cras mattis consectetur purus sit amet fermentum aenean lacinia bibendum nulla sed consectetur etiam porta sem malesuada magna mollis euismod donec ullamcorper nullam quis risus eget urna mollis ornare vel eu leo fringilla.",
    linkedin: "https://www.linkedin.com/in/jim-reynolds-placeholder",
  },
  {
    name: "Austin Reynolds",
    role: "Product",
    photo: "/images/team/placeholder-austin-reynolds.svg",
    bio: "Vivamus sagittis lacus vel augue laoreet rutrum faucibus dolor auctor donec id elit non mi porta gravida at eget metus curabitur blandit tempus porttitor integer posuere erat a ante venenatis dapibus posuere velit aliquet cras justo odio dapibus in euismod.",
    linkedin: "https://www.linkedin.com/in/austin-reynolds-placeholder",
  },
];
---

<section id="team" class="bg-surface-inset py-24 lg:py-32">
  <div class="mx-auto max-w-[1200px] px-6 lg:px-16">
    <div class="mb-16 text-center">
      <p
        class="text-brand-400 animate-on-scroll mb-4 text-sm font-semibold tracking-widest uppercase"
      >
        Who we are
      </p>
      <h2
        class="font-heading text-text-primary animate-on-scroll mb-5 text-3xl font-semibold sm:text-4xl lg:text-[41px]"
      >
        Built by people who've been in your shoes
      </h2>
      <p
        class="text-text-secondary animate-on-scroll mx-auto max-w-2xl text-lg"
      >
        Innovise was founded on a simple idea: the software your business runs
        on should be built for your business. Our leadership combines deep
        technical expertise with real-world business perspective.
      </p>
    </div>

    <div class="stagger-children mx-auto grid max-w-4xl gap-8 md:grid-cols-2">
      {
        team.map((member) => (
          <div class="bg-surface-card border-surface-inset rounded-lg border p-8 text-center transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_4px_18px_rgba(0,0,0,0.08)]">
            <img
              src={member.photo}
              alt={member.name}
              class="border-surface-inset mx-auto mb-6 h-28 w-28 rounded-full border-4 object-cover"
            />
            <h3 class="font-heading text-text-primary text-xl font-semibold">
              {member.name}
            </h3>
            <p class="text-brand-400 mb-4 text-sm font-medium">{member.role}</p>
            <p class="text-text-secondary mb-5 text-[15px] leading-relaxed">
              {member.bio}
            </p>
            <a
              href={member.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-tertiary hover:text-brand-500 inline-flex items-center gap-2 text-sm transition-colors"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
              LinkedIn
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
