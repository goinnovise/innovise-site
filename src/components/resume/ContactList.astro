---
import type { CollectionEntry } from "astro:content";

type Contact = CollectionEntry<"resumes">["data"]["contact"];

interface Props {
  contact: Contact;
}

const { contact } = Astro.props;

interface ChannelDef {
  key: keyof Contact;
  icon: string;
  href: (value: string) => string;
  label: (value: string) => string;
  external: boolean;
}

const channels: ChannelDef[] = [
  {
    key: "email",
    icon: `<path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z" /><path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z" />`,
    href: (v) => `mailto:${v}`,
    label: (v) => v,
    external: false,
  },
  {
    key: "phone",
    icon: `<path fill-rule="evenodd" d="M1.5 4.5a3 3 0 0 1 3-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 0 1-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 0 0 6.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 0 1 1.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 0 1-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5Z" clip-rule="evenodd" />`,
    href: (v) => `tel:${v.replace(/[^+\d]/g, "")}`,
    label: (v) => v,
    external: false,
  },
  {
    key: "website",
    icon: `<path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM6.262 6.072a8.25 8.25 0 1 0 10.562-.766 4.5 4.5 0 0 1-1.318 1.357L14.25 7.5l.165.33a.809.809 0 0 1-1.086 1.085l-.604-.302a1.125 1.125 0 0 0-1.298.21l-.132.131c-.439.44-.439 1.152 0 1.591l.296.296c.256.257.622.374.98.314l1.17-.195c.323-.054.654.036.905.245l1.33 1.108c.32.267.46.694.358 1.1a8.7 8.7 0 0 1-2.288 4.04l-.723.724a1.125 1.125 0 0 1-1.298.21l-.153-.076a1.125 1.125 0 0 1-.622-1.006v-1.089c0-.298-.119-.585-.33-.796l-1.347-1.347a1.125 1.125 0 0 1-.21-1.298L9.75 12l-1.64-1.64a6 6 0 0 1-1.595-2.872l-.18-.722a4.503 4.503 0 0 1-.073-.694Z" clip-rule="evenodd" />`,
    href: (v) => (v.startsWith("http") ? v : `https://${v}`),
    label: (v) => v,
    external: true,
  },
  {
    key: "linkedin",
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />`,
    href: (v) => `https://www.linkedin.com/in/${v}/`,
    label: () => "LinkedIn",
    external: true,
  },
  {
    key: "github",
    icon: `<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.5 11.5 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />`,
    href: (v) => `https://github.com/${v}`,
    label: () => "GitHub",
    external: true,
  },
  {
    key: "stackOverflow",
    icon: `<path d="M17.36 20.2v-5.38h1.79V22H3v-7.18h1.8v5.38h12.56zm-9.69-1.79h8.58v-1.79H7.67v1.79zM7.93 14l8.4 1.74.37-1.74-8.41-1.74-.36 1.74zm1.05-4.04l7.78 3.6.74-1.59-7.78-3.62-.74 1.61zM11.04 6.1l6.6 5.49 1.13-1.36-6.62-5.49-1.11 1.36zM15.69 1l-1.45 1.06 5.13 6.92 1.44-1.05L15.69 1z" />`,
    href: (v) => `https://stackoverflow.com/users/${v}`,
    label: () => "Stack Overflow",
    external: true,
  },
];

const present = channels.filter((c) => Boolean(contact[c.key]));
---

{
  present.length > 0 && (
    <ul class="resume-contact mt-6 space-y-2 text-sm text-white/90">
      {present.map((c) => {
        const value = contact[c.key] as string;
        return (
          <li class="flex items-start gap-3">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
              set:html={c.icon}
            />
            <a
              href={c.href(value)}
              class="break-words text-white/90 underline-offset-2 hover:text-white hover:underline"
              target={c.external ? "_blank" : undefined}
              rel={c.external ? "noopener noreferrer" : undefined}
            >
              {c.label(value)}
            </a>
          </li>
        );
      })}
    </ul>
  )
}
