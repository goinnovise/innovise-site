---

---

<section class="bg-brand-500 relative overflow-hidden py-24 lg:py-32">
  <!-- Pattern -->
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"
  >
  </div>

  <div class="relative mx-auto max-w-[1200px] px-6 text-center lg:px-16">
    <h2
      class="font-heading animate-on-scroll mb-5 text-3xl font-bold text-white sm:text-4xl lg:text-[46px]"
    >
      Ready to build something great?
    </h2>
    <p class="animate-on-scroll mx-auto mb-10 max-w-xl text-lg text-white/70">
      Whether you have a detailed spec or just a napkin sketch, we'd love to
      hear about your project.
    </p>
    <div
      class="animate-on-scroll flex flex-col justify-center gap-4 sm:flex-row"
    >
      <a
        href="#contact"
        class="text-brand-500 hover:bg-surface-page inline-flex items-center justify-center rounded-lg bg-white px-8 py-4 text-base font-semibold transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg"
      >
        Get in touch
        <svg
          class="ml-2 h-5 w-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
      <a
        href="#services"
        class="inline-flex items-center justify-center rounded-lg border border-white/20 px-8 py-4 text-base font-semibold text-white/90 transition-all duration-200 hover:bg-white/10"
      >
        View our services
      </a>
    </div>
  </div>
</section>
