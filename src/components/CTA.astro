---
---

<section class="relative py-24 lg:py-32 bg-brand-500 overflow-hidden">
  <!-- Pattern -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="relative max-w-[1200px] mx-auto px-6 lg:px-16 text-center">
    <h2 class="font-heading text-3xl sm:text-4xl lg:text-[46px] font-bold text-white mb-5 animate-on-scroll">
      Ready to build something great?
    </h2>
    <p class="text-lg text-white/70 max-w-xl mx-auto mb-10 animate-on-scroll">
      Whether you have a detailed spec or just a napkin sketch, we'd love to hear about your project.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll">
      <a
        href="#contact"
        class="inline-flex items-center justify-center bg-white text-brand-500 font-semibold px-8 py-4 rounded-lg text-base hover:bg-surface-page hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200"
      >
        Get in touch
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="#services"
        class="inline-flex items-center justify-center text-white/90 font-semibold px-8 py-4 rounded-lg text-base border border-white/20 hover:bg-white/10 transition-all duration-200"
      >
        View our services
      </a>
    </div>
  </div>
</section>
