---

---

<section class="relative overflow-hidden py-24 lg:py-32">
  <!-- Seattle skyline background -->
  <picture>
    <source srcset="/images/content/seattle-skyline.webp" type="image/webp" />
    <img
      src="/images/content/seattle-skyline.jpg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover object-center"
      loading="lazy"
    />
  </picture>

  <!-- Dark overlay — brand red tint on top of photo -->
  <div class="absolute inset-0 bg-neutral-950/75"></div>
  <!-- Subtle red bleed on left edge -->
  <div
    class="from-brand-500/40 absolute inset-0 bg-gradient-to-r to-transparent"
  >
  </div>

  <div class="relative mx-auto max-w-[1200px] px-6 text-center lg:px-16">
    <p
      class="text-brand-300 animate-on-scroll mb-4 text-sm font-semibold tracking-widest uppercase"
    >
      Bellevue, WA · serving clients nationwide
    </p>
    <h2
      class="font-heading animate-on-scroll mb-5 text-3xl font-bold text-white sm:text-4xl lg:text-[46px]"
    >
      Have a project worth building?
    </h2>
    <p class="animate-on-scroll mx-auto mb-10 max-w-xl text-lg text-white/70">
      Tell us what you're trying to accomplish. We'll be direct about whether
      Innovise is the right fit.
    </p>
    <div
      class="animate-on-scroll flex flex-col justify-center gap-4 sm:flex-row"
    >
      <a
        href="#contact"
        class="text-brand-500 hover:bg-surface-page inline-flex items-center justify-center rounded-lg bg-white px-8 py-4 text-base font-semibold transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg"
      >
        Get in touch
        <svg
          class="ml-2 h-5 w-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
      <a
        href="/services/"
        class="inline-flex items-center justify-center rounded-lg border border-white/25 px-8 py-4 text-base font-semibold text-white/90 transition-all duration-200 hover:bg-white/10"
      >
        View our services
      </a>
    </div>
  </div>
</section>
