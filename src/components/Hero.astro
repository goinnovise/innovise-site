---
---

<section id="home" class="relative bg-brand-500 min-h-[90vh] flex items-center overflow-hidden">
  <!-- Subtle pattern overlay -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>

  <!-- Gradient overlay at bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-brand-700/30 to-transparent"></div>

  <div class="relative max-w-[1200px] mx-auto px-6 lg:px-16 py-32 w-full">
    <div class="max-w-3xl">
      <p class="text-brand-100 text-sm font-semibold tracking-widest uppercase mb-6 animate-on-scroll">
        Custom Software Consulting
      </p>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-[65px] font-bold text-white leading-[1.1] mb-8 animate-on-scroll">
        Software that fits your business — not the other way around.
      </h1>
      <p class="text-lg sm:text-xl text-white/75 leading-relaxed max-w-2xl mb-10 animate-on-scroll">
        We design, build, and maintain custom software solutions tailored to how your business actually works. From startups to Fortune 50, Innovise is the development partner that scales with you.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 animate-on-scroll">
        <a
          href="#contact"
          class="inline-flex items-center justify-center bg-white text-brand-500 font-semibold px-8 py-4 rounded-lg text-base hover:bg-surface-page hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200"
        >
          Let's build together
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="#services"
          class="inline-flex items-center justify-center text-white/90 font-semibold px-8 py-4 rounded-lg text-base border border-white/20 hover:bg-white/10 transition-all duration-200"
        >
          See our services
        </a>
      </div>
    </div>
  </div>
</section>
