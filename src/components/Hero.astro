---

---

<section
  id="home"
  class="bg-brand-500 relative flex min-h-[90vh] items-center overflow-hidden"
>
  <!-- Hero photo: extra height + scroll parallax (see script) -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <div
      id="hero-parallax-bg"
      class="absolute -top-[12%] left-0 h-[124%] w-full bg-cover bg-left bg-no-repeat will-change-transform"
      style="background-image: url('/images/hero-bg.png');"
    >
    </div>
  </div>

  <!-- Brand tint: strong at top, fades to fully transparent toward the bottom -->
  <div
    class="from-brand-500/95 via-brand-500/45 absolute inset-0 bg-gradient-to-b to-transparent"
    aria-hidden="true"
  >
  </div>

  <!-- Subtle pattern overlay -->
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"
  >
  </div>

  <div class="relative mx-auto w-full max-w-[1200px] px-6 py-32 lg:px-16">
    <div class="max-w-3xl">
      <p
        class="text-brand-100 animate-on-scroll mb-6 text-sm font-semibold tracking-widest uppercase"
      >
        Engineering Partner
      </p>
      <h1
        class="font-heading animate-on-scroll mb-8 text-4xl leading-[1.1] font-bold text-white sm:text-5xl lg:text-[65px]"
      >
        Your engineering team, without the overhead of building one.
      </h1>
      <p
        class="animate-on-scroll mb-10 max-w-2xl text-lg leading-relaxed text-white/75 sm:text-xl"
      >
        Whether you need a team to build from scratch, senior engineers to add
        bandwidth, or technical leadership to guide a fast-moving project —
        Innovise embeds with your business and builds what it actually needs. No
        handoffs. No account managers. Senior engineers from day one.
      </p>
      <div class="animate-on-scroll flex flex-col gap-4 sm:flex-row">
        <a
          href="#contact"
          class="text-brand-500 hover:bg-surface-page inline-flex items-center justify-center rounded-lg bg-white px-8 py-4 text-base font-semibold transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg"
        >
          Let's build together
          <svg
            class="ml-2 h-5 w-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        <a
          href="#services"
          class="inline-flex items-center justify-center rounded-lg border border-white/20 px-8 py-4 text-base font-semibold text-white/90 transition-all duration-200 hover:bg-white/10"
        >
          See our services
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  function initHeroParallax() {
    const bg = document.getElementById("hero-parallax-bg");
    if (!bg) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const rate = 0.32;
    let ticking = false;

    function update() {
      const y = window.scrollY * rate;
      bg.style.transform = `translate3d(0, ${y}px, 0)`;
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    update();
  }

  initHeroParallax();
</script>
