---

<section id="services" class="bg-surface-page py-24 lg:py-32">
  <div class="mx-auto max-w-[1200px] px-6 lg:px-16">
    <div class="mb-16 text-center">
      <p
        class="text-brand-500 animate-on-scroll mb-4 text-sm font-semibold tracking-widest uppercase"
      >
        What we do
      </p>
      <h2
        class="font-heading text-text-primary animate-on-scroll mb-5 text-3xl font-semibold sm:text-4xl lg:text-[41px]"
      >
        Services built around your situation
      </h2>
      <p class="text-text-secondary animate-on-scroll mx-auto max-w-xl text-lg">
        From embedded teams to production readiness, Innovise works in the
        situations where standard dev shops fall short.
      </p>
    </div>

    <div class="stagger-children grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <a
            href={service.href}
            class="group bg-surface-card border-surface-inset flex flex-col rounded-lg border p-8 transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_4px_18px_rgba(0,0,0,0.08)]"
          >
            <div class="bg-brand-50 group-hover:bg-brand-500 mb-5 flex h-12 w-12 items-center justify-center rounded-lg transition-colors duration-200">
              <svg
                class="text-brand-500 h-6 w-6 transition-colors duration-200 group-hover:text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                set:html={service.icon}
              />
            </div>
            {service.eyebrow && (
              <p class="text-brand-500 mb-2 text-xs font-semibold tracking-widest uppercase">
                {service.eyebrow}
              </p>
            )}
            <h3 class="font-heading text-text-primary mb-3 text-lg font-semibold">
              {service.title}
            </h3>
            <p class="text-text-secondary mb-6 leading-relaxed">
              {service.description}
            </p>
            <span class="text-brand-500 group-hover:text-brand-600 mt-auto inline-flex items-center text-sm font-semibold transition-colors">
              Learn more
              <svg
                class="ml-1.5 h-4 w-4 transition-transform group-hover:translate-x-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"
                />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
