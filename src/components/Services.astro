---
const services = [
  {
    title: "Custom software development",
    description:
      "Full-stack development across web, desktop, and mobile. Senior engineers build the right thing, the right way — and hand it over in a state your team can actually maintain.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />`,
  },
  {
    title: "Fractional technical leadership",
    description:
      "Senior engineering leadership for companies that need a CTO-level mind in the room — not just in meetings. Architecture decisions, hiring guidance, team structure, and hands-on direction when it counts.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m15 12-9.373 9.373a1 1 0 0 1-3.001-3L12 9"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m18 15 4-4"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172v-.344a2 2 0 0 0-.586-1.414l-1.657-1.657A6 6 0 0 0 12.516 3H9l1.243 1.243A6 6 0 0 1 12 8.485V10l2 2h1.172a2 2 0 0 1 1.414.586L18.5 14.5"/>`,
  },
  {
    title: "System integrations",
    description:
      "Connect your platforms, automate your workflows, and eliminate the manual work that slows your team down. Senior engineers build integrations that hold up under real load — not glue code that breaks in month two.",
    icon: `<circle cx="5" cy="6" r="3" stroke-width="1.5"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6h5a2 2 0 0 1 2 2v7"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m15 9-3-3 3-3"/><circle cx="19" cy="18" r="3" stroke-width="1.5"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18H7a2 2 0 0 1-2-2V9"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m9 15 3 3-3 3"/>`,
  },
  {
    title: "Systems design & architecture",
    description:
      "Before a line of code is written, senior engineers map out the full system — data flows, failure modes, scaling decisions, and the edge cases that only experience reveals. Built right the first time.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 22V7a1 1 0 0 0-1-1H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5a1 1 0 0 0-1-1H2"/><rect x="14" y="2" width="8" height="8" rx="1" stroke-width="1.5"/>`,
  },
  {
    title: "DevOps & cloud infrastructure",
    description:
      "CI/CD pipelines, containerization, cloud infrastructure, and monitoring — built by engineers who've run production systems at scale. Ship with confidence and know when something breaks before your users do.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />`,
  },
  {
    title: "UX & interface design",
    description:
      "Interfaces designed for how users actually behave — not how we imagine they will. From information architecture to final pixels, every decision is grounded in research and tested against real use.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />`,
  },
];
---

<section id="services" class="bg-surface-page py-24 lg:py-32">
  <div class="mx-auto max-w-[1200px] px-6 lg:px-16">
    <div class="mb-16 text-center">
      <p
        class="text-brand-400 animate-on-scroll mb-4 text-sm font-semibold tracking-widest uppercase"
      >
        What we do
      </p>
      <h2
        class="font-heading text-text-primary animate-on-scroll mb-5 text-3xl font-semibold sm:text-4xl lg:text-[41px]"
      >
        Engineering across your entire stack
      </h2>
      <p class="text-text-secondary animate-on-scroll mx-auto max-w-xl text-lg">
        We don't just write code. We solve the business problems behind it.
      </p>
    </div>

    <div class="stagger-children grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <div class="group bg-surface-card border-surface-inset rounded-lg border p-8 transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_4px_18px_rgba(0,0,0,0.08)]">
            <div class="bg-brand-50 group-hover:bg-brand-500 mb-5 flex h-12 w-12 items-center justify-center rounded-lg transition-colors duration-200">
              <svg
                class="text-brand-500 h-6 w-6 transition-colors duration-200 group-hover:text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                set:html={service.icon}
              />
            </div>
            <h3 class="font-heading text-text-primary mb-3 text-lg font-semibold">
              {service.title}
            </h3>
            <p class="text-text-secondary leading-relaxed">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
