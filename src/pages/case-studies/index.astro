---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

// Sorted for stable, predictable order — not as a recency-foregrounding
// affordance. Cards do not surface the publish date as a card-level element
// (R4: recency is not foregrounded on the landing surface).
const caseStudies = (await getCollection("caseStudies")).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const pageTitle = "Case studies — engineering work, real outcomes | Innovise";
const pageDescription =
  "Real client engagements: what the situation was, what Innovise tried, what shipped, and what changed. Custom software, MVP stabilization, offshore-to-onshore transitions, and more.";
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <main>
    <!-- Hero -->
    <section class="bg-brand-500 relative overflow-hidden py-24 lg:py-32">
      <div class="relative mx-auto max-w-[1200px] px-6 lg:px-16">
        <nav class="mb-6 text-sm text-white/60" aria-label="Breadcrumb">
          <a href="/" class="transition-colors hover:text-white">Home</a>
          <span class="mx-2">›</span>
          <span class="text-white">Case studies</span>
        </nav>
        <p
          class="animate-on-scroll text-brand-100 mb-6 text-sm font-semibold tracking-widest uppercase"
        >
          Case studies · client outcomes
        </p>
        <h1
          class="animate-on-scroll font-heading mb-6 text-4xl leading-[1.1] font-bold text-white sm:text-5xl lg:text-[58px]"
        >
          Real engagements, real outcomes
        </h1>
        <p
          class="mb-2 max-w-2xl text-lg leading-relaxed text-white/80 sm:text-xl"
        >
          What the situation was, what Innovise tried, what shipped, and what
          changed. Every case study below is a real client engagement.
        </p>
      </div>
    </section>

    <!-- Card grid or empty-state -->
    <section class="bg-surface-page py-24 lg:py-32">
      <div class="mx-auto max-w-[1200px] px-6 lg:px-16">
        {
          caseStudies.length === 0 ? (
            <div class="mx-auto max-w-2xl text-center">
              <p class="text-text-secondary text-lg leading-relaxed">
                No case studies published yet.
              </p>
              <p class="text-text-tertiary mt-3 text-base leading-relaxed">
                If you'd like to talk about an engagement that doesn't yet have
                a public write-up,{" "}
                <a
                  href="/#contact"
                  class="text-brand-500 underline underline-offset-4 hover:text-brand-600"
                >
                  start a conversation
                </a>
                .
              </p>
            </div>
          ) : (
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              {caseStudies.map((entry) => (
                <a
                  href={`/case-studies/${entry.id}/`}
                  class="group animate-on-scroll bg-surface-card border-surface-inset flex flex-col rounded-xl border p-7 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg"
                >
                  <p class="text-brand-500 mb-4 text-xs font-semibold tracking-widest uppercase">
                    Outcome
                  </p>
                  <p class="font-heading text-text-primary mb-4 text-xl leading-tight font-semibold sm:text-2xl">
                    {entry.data.outcome}
                  </p>
                  <p class="text-text-primary mb-3 text-base font-semibold">
                    {entry.data.title}
                  </p>
                  <p class="text-text-secondary mb-6 text-sm leading-relaxed">
                    {entry.data.summary}
                  </p>
                  <span class="text-brand-500 mt-auto inline-flex items-center text-sm font-semibold">
                    Read the case study
                    <svg
                      class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                      />
                    </svg>
                  </span>
                </a>
              ))}
            </div>
          )
        }
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-brand-500 py-24 lg:py-32">
      <div class="mx-auto max-w-[1200px] px-6 text-center lg:px-16">
        <h2
          class="animate-on-scroll font-heading mb-6 text-3xl font-bold text-white sm:text-4xl lg:text-[41px]"
        >
          Have a situation worth a conversation?
        </h2>
        <p class="mx-auto mb-10 max-w-xl text-lg text-white/80">
          Start with a call. Innovise will be direct about what's realistic and
          what the right approach looks like for your situation.
        </p>
        <a
          href="/#contact"
          class="text-brand-500 hover:bg-surface-page inline-flex items-center justify-center rounded-lg bg-white px-8 py-4 text-base font-semibold transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg"
        >
          Get in touch
          <svg
            class="ml-2 h-5 w-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
