---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

// Sort newest-first by publishDate. Unlike case-studies (R4: recency is not
// foregrounded), articles surface recency on the listing because freshness
// is a useful signal for SEO/editorial content. Drafts are filtered out.
const articles = (await getCollection("articles", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const featured = articles.find((a) => a.data.featured) ?? articles[0];
const rest = articles.filter((a) => a !== featured);

const pageTitle = "Articles — practical engineering, AI, and leadership notes | Innovise";
const pageDescription =
  "Frameworks, checklists, and direct takes from a senior software engineer. Production AI, MVP-to-production, fractional CTO work, embedded teams, and technical audits.";

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <main>
    <!-- Hero -->
    <section class="bg-brand-500 relative overflow-hidden py-24 lg:py-32">
      <div class="relative mx-auto max-w-[1200px] px-6 lg:px-16">
        <nav class="mb-6 text-sm text-white/60" aria-label="Breadcrumb">
          <a href="/" class="transition-colors hover:text-white">Home</a>
          <span class="mx-2">›</span>
          <span class="text-white">Articles</span>
        </nav>
        <p
          class="animate-on-scroll text-brand-100 mb-6 text-sm font-semibold tracking-widest uppercase"
        >
          Articles · practical notes
        </p>
        <h1
          class="animate-on-scroll font-heading mb-6 text-4xl leading-[1.1] font-bold text-white sm:text-5xl lg:text-[58px]"
        >
          Engineering you can use on Monday
        </h1>
        <p
          class="mb-2 max-w-2xl text-lg leading-relaxed text-white/80 sm:text-xl"
        >
          Frameworks, checklists, and direct takes on production AI,
          MVP-to-production work, fractional CTO decisions, embedded teams, and
          technical audits.
        </p>
      </div>
    </section>

    <!-- Card grid or empty-state -->
    <section class="bg-surface-page py-24 lg:py-32">
      <div class="mx-auto max-w-[1200px] px-6 lg:px-16">
        {
          articles.length === 0 ? (
            <div class="mx-auto max-w-2xl text-center">
              <p class="text-text-secondary text-lg leading-relaxed">
                No articles published yet. Check back soon — or{" "}
                <a
                  href="/#contact"
                  class="text-brand-500 underline underline-offset-4 hover:text-brand-600"
                >
                  start a conversation
                </a>{" "}
                if you have a topic you'd like a senior take on.
              </p>
            </div>
          ) : (
            <>
              {featured && (
                <a
                  href={`/articles/${featured.id}/`}
                  class="group animate-on-scroll bg-surface-card border-surface-inset mb-12 flex flex-col gap-8 rounded-xl border p-8 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg md:flex-row md:items-center md:p-10"
                >
                  {featured.data.heroImage && (
                    <div class="md:w-2/5">
                      <img
                        src={featured.data.heroImage}
                        alt={featured.data.heroImageAlt ?? ""}
                        loading="lazy"
                        class="aspect-[16/10] w-full rounded-lg object-cover"
                      />
                    </div>
                  )}
                  <div class={featured.data.heroImage ? "md:w-3/5" : "w-full"}>
                    <p class="text-brand-500 mb-3 text-xs font-semibold tracking-widest uppercase">
                      Featured · {formatDate(featured.data.publishDate)}
                    </p>
                    <p class="font-heading text-text-primary mb-4 text-2xl leading-tight font-semibold sm:text-3xl">
                      {featured.data.title}
                    </p>
                    <p class="text-text-secondary mb-6 text-base leading-relaxed">
                      {featured.data.description}
                    </p>
                    <span class="text-brand-500 inline-flex items-center text-sm font-semibold">
                      Read the article
                      <svg
                        class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M17 8l4 4m0 0l-4 4m4-4H3"
                        />
                      </svg>
                    </span>
                  </div>
                </a>
              )}

              {rest.length > 0 && (
                <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                  {rest.map((entry) => (
                    <a
                      href={`/articles/${entry.id}/`}
                      class="group animate-on-scroll bg-surface-card border-surface-inset flex flex-col rounded-xl border p-7 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg"
                    >
                      <p class="text-brand-500 mb-3 text-xs font-semibold tracking-widest uppercase">
                        {formatDate(entry.data.publishDate)}
                      </p>
                      <p class="font-heading text-text-primary mb-4 text-xl leading-tight font-semibold sm:text-2xl">
                        {entry.data.title}
                      </p>
                      <p class="text-text-secondary mb-6 text-sm leading-relaxed">
                        {entry.data.description}
                      </p>
                      <span class="text-brand-500 mt-auto inline-flex items-center text-sm font-semibold">
                        Read the article
                        <svg
                          class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"
                          />
                        </svg>
                      </span>
                    </a>
                  ))}
                </div>
              )}
            </>
          )
        }
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-brand-500 py-24 lg:py-32">
      <div class="mx-auto max-w-[1200px] px-6 text-center lg:px-16">
        <h2
          class="animate-on-scroll font-heading mb-6 text-3xl font-bold text-white sm:text-4xl lg:text-[41px]"
        >
          Working on a problem these touch on?
        </h2>
        <p class="mx-auto mb-10 max-w-xl text-lg text-white/80">
          Start with a conversation. Innovise will be direct about what's
          realistic and what the right approach looks like for your situation.
        </p>
        <a
          href="/#contact"
          class="text-brand-500 hover:bg-surface-page inline-flex items-center justify-center rounded-lg bg-white px-8 py-4 text-base font-semibold transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg"
        >
          Get in touch
          <svg
            class="ml-2 h-5 w-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
