---
import "../styles/resume-print.css";
import type { CollectionEntry } from "astro:content";
import ProfileBlock from "../components/resume/ProfileBlock.astro";
import ContactList from "../components/resume/ContactList.astro";
import CareerProfile from "../components/resume/CareerProfile.astro";
import ExperienceList from "../components/resume/ExperienceList.astro";
import EducationList from "../components/resume/EducationList.astro";
import SkillsList from "../components/resume/SkillsList.astro";
import ProjectsList from "../components/resume/ProjectsList.astro";
import PublicationsList from "../components/resume/PublicationsList.astro";
import LanguagesList from "../components/resume/LanguagesList.astro";
import InterestsList from "../components/resume/InterestsList.astro";

interface Props {
  resume: CollectionEntry<"resumes">["data"];
  slug: string;
}

const { resume, slug } = Astro.props;
const educationInSidebar = resume.display?.educationInSidebar ?? true;
const buildDate = new Date().toISOString().slice(0, 10);
---

<header class="resume-header bg-surface-page border-b border-black/5">
  <div class="mx-auto flex max-w-[1200px] items-center px-6 py-4 lg:px-12">
    <a href="/" class="inline-flex items-center" aria-label="Innovise home">
      <picture>
        <source
          srcset="/images/logo/innovise-main-logo.webp"
          type="image/webp"
        />
        <img
          src="/images/logo/innovise-main-logo-opt.png"
          alt="Innovise Technologies"
          width="600"
          height="180"
          class="h-8 w-auto"
        />
      </picture>
    </a>
  </div>
</header>

<main class="bg-surface-page">
  <div class="mx-auto max-w-[1200px] px-6 py-10 lg:px-12 lg:py-14">
    <div class="bg-surface-card overflow-hidden rounded-xl shadow-sm">
      <div class="resume-grid grid grid-cols-1 lg:grid-cols-[1fr_320px]">
        {/* Main column */}
        <div class="resume-main relative px-6 py-10 lg:px-12 lg:py-14">
          <button
            type="button"
            class="resume-print-button bg-brand-500 hover:bg-brand-600 absolute top-4 right-4 inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold text-white transition-colors print:hidden"
            data-resume-print-button
            aria-label="Print or save resume as PDF"
          >
            <svg
              class="h-4 w-4"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M7.875 1.5C6.839 1.5 6 2.34 6 3.375v2.99c-.426.053-.851.114-1.274.184-1.454.241-2.476 1.5-2.476 2.917v6.198a3 3 0 0 0 3 3h.27l-.155 1.705A1.875 1.875 0 0 0 7.232 22.5h9.536a1.875 1.875 0 0 0 1.867-2.131l-.155-1.705h.27a3 3 0 0 0 3-3V9.466c0-1.417-1.022-2.676-2.476-2.917A48.716 48.716 0 0 0 18 6.366V3.375c0-1.036-.84-1.875-1.875-1.875h-8.25ZM16.5 6.205v-2.83A.375.375 0 0 0 16.125 3h-8.25a.375.375 0 0 0-.375.375v2.83a49.353 49.353 0 0 1 9 0Zm-.217 8.265c.178.018.317.16.333.337l.526 5.784a.375.375 0 0 1-.374.409H7.232a.375.375 0 0 1-.374-.409l.526-5.784a.373.373 0 0 1 .333-.337 41.741 41.741 0 0 1 8.566 0Zm.967-3.97a.75.75 0 0 1 .75-.75h.008a.75.75 0 0 1 .75.75v.008a.75.75 0 0 1-.75.75h-.008a.75.75 0 0 1-.75-.75v-.008Z"
                clip-rule="evenodd"
              ></path>
            </svg>
            Print / Save as PDF
          </button>

          <div class="space-y-9">
            <CareerProfile data={resume.careerProfile} />
            <ExperienceList experiences={resume.experiences} />
            {!educationInSidebar && (
              <EducationList education={resume.education} variant="main" />
            )}
            <SkillsList skills={resume.skills} />
            <ProjectsList projects={resume.projects} />
            <PublicationsList publications={resume.publications} />
          </div>
        </div>

        {/* Sidebar (right) */}
        <aside
          class="resume-sidebar bg-brand-500 text-white px-6 py-10 lg:px-8 lg:py-14 print:bg-[var(--color-text-primary)]"
        >
          <ProfileBlock profile={resume.profile} />
          <ContactList contact={resume.contact} />
          {educationInSidebar && (
            <EducationList education={resume.education} variant="sidebar" />
          )}
          <LanguagesList languages={resume.languages} />
          <InterestsList interests={resume.interests} />
        </aside>
      </div>
    </div>

    <small class="resume-print-footer">
      Generated {buildDate} · current version at goinnovise.com/resumes/{slug}/
    </small>
  </div>
</main>

<footer class="resume-footer bg-surface-page border-t border-black/5">
  <div
    class="text-text-tertiary mx-auto flex max-w-[1200px] flex-wrap items-center justify-between gap-2 px-6 py-6 text-sm lg:px-12"
  >
    <p>&copy; 2026 Innovise, LLC. All rights reserved.</p>
    <a
      href="https://www.linkedin.com/company/innovise-technology"
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-brand-500 inline-flex items-center gap-2 transition-colors"
    >
      <svg
        class="h-4 w-4"
        fill="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
        ></path>
      </svg>
      LinkedIn
    </a>
  </div>
</footer>

<script>
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement | null;
    if (!target) return;
    const btn = target.closest("[data-resume-print-button]");
    if (btn) {
      e.preventDefault();
      window.print();
    }
  });
</script>
